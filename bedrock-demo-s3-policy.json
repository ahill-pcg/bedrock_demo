{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3ListBucket",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::griboullie-bedrock-demo"
    },
    {
      "Sid": "S3AccessDemoPrefix",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject"],
      "Resource": ["arn:aws:s3:::griboullie-bedrock-demo/bedrock-demo/*"]
    }
  ]
}
